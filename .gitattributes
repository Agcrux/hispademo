*.psd filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text

# The web-ready copies must be real blobs, not LFS pointers. Vercel clones without
# running `git lfs pull`, so anything left in LFS deploys as a ~130-byte text stub
# that the browser renders as a broken image. Only ~19 MB, so plain git is fine.
# The full-size originals stay in LFS: the site never requests them.
photos/web/*.jpg -filter -diff -merge -text
photos/web-lg/*.jpg -filter -diff -merge -text
